// Problem Link: https://leetcode.com/problems/final-value-of-variable-after-performing-operations/

class Solution {
public:
    int finalValueAfterOperations(vector<string>& operations) {
        int X = 0;
        int n = operations.size();

        for (int i = 0; i < n; i++) {
            if (operations[i] == "++X") {
                ++X;
            }
            if (operations[i] == "X++") {
                X++;
            }
            if (operations[i] == "--X") {
                --X;
            }
            if (operations[i] == "X--") {
                X--;
            }
        }
        return X;
    }
};