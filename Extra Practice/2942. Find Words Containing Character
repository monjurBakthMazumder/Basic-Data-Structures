// Problem Link: https://leetcode.com/problems/find-words-containing-character/

class Solution {
public:
    vector<int> findWordsContaining(vector<string>& words, char x) {
        int n = words.size();

        vector<int> v;
        for (int i = 0; i < n; i++) {
            string s = words[i];
            int n2 = s.size();
            for (int j = 0; j < n2; j++) {
                if (s[j] == x) {
                    v.push_back(i);
                    break;
                }
            }
        }
        return v;
    }
};