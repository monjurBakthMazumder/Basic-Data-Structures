 // Problem Link:  https://leetcode.com/problems/the-two-sneaky-numbers-of-digitville/

 class Solution {
public:
    vector<int> getSneakyNumbers(vector<int>& nums) {
        vector<int> v(2, -1);
        int n = nums.size();

        for (int i = 0; i < n - 1; i++) {
            for (int j = i + 1; j < n; j++) {
                if (nums[i] == nums[j]) {
                    if (nums[i] != v[0] && nums[i] != v[1]) {
                        if (v[0] == -1) {
                            v[0] = nums[i];
                        } else {
                            v[1] = nums[i];
                        }
                    }
                }
            }
        }

        return v;
    }
};